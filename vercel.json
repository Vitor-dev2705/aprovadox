{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["backend/**"] }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/src/server.js" },
    { "src": "/uploads/(.*)", "dest": "backend/src/server.js" },
    { "src": "/assets/(.*)", "dest": "frontend/dist/assets/$1" },
    { "src": "/favicon.svg", "dest": "frontend/dist/favicon.svg" },
    { "src": "/(.*\\.(svg|png|jpg|jpeg|gif|ico|webp|woff|woff2))", "dest": "frontend/dist/$1" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html" }
  ]
}
